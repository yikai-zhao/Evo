{
  "name": "evo",
  "version": "3.13.0",
  "description": "Twilight of the Gods — a multiplayer mythic battle royale on the open web.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "node scripts/smoke-test.js",
    "version:sync": "node scripts/sync-version.js",
    "version:check": "node scripts/sync-version.js --check",
    "prebuild": "node scripts/sync-version.js && node scripts/smoke-test.js",
    "build": "node scripts/build-platform.js",
    "build:crazygames": "node scripts/build-platform.js --platform=crazygames",
    "build:poki": "node scripts/build-platform.js --platform=poki",
    "build:itch": "node scripts/build-platform.js --platform=itch",
    "gen:portraits": "node scripts/gen-portraits.mjs",
    "gen:portraits:force": "node scripts/gen-portraits.mjs --force",
    "start:electron": "electron electron-main.js",
    "build:electron": "electron-builder --config electron-builder.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yikai-zhao/Evo.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/yikai-zhao/Evo/issues"
  },
  "homepage": "https://github.com/yikai-zhao/Evo#readme",
  "dependencies": {
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0",
    "sharp": "^0.34.5",
    "terser": "^5.48.0"
  }
}
